{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend",
      "type": "shell",
      "command": "python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/src/backend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "frontend",
      "type": "shell",
      "command": "npm run dev --host",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "start-all",
      "dependsOn": ["backend", "frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
