{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend",
      "type": "shell",
      "command": "python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/src/backend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "frontend",
      "type": "shell",
      "command": "npm run dev -- --host",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "browser",
      "type": "shell",
      "command": "\"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\" --kiosk http://localhost:5173",
    },
    {
      "label": "start-all",
      "dependsOn": ["backend", "frontend", "browser"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
